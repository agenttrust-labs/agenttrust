# @agenttrust/trustgate-server — environment overrides
#
# The facilitator service. Mounts AgentTrust onto an Express app +
# exposes /verify, /settle, /dispute, /receipt/:hash. Required env
# below; everything else has a built-in default.

# Solana RPC endpoint. Falls back to devnet's public endpoint.
RPC_URL=https://api.devnet.solana.com

# Network slug. solana-devnet | solana-mainnet
NETWORK=solana-devnet

# REQUIRED: base58-encoded 64-byte secret key for the facilitator's
# emit_feedback signer. NEVER commit a real value.
FACILITATOR_KEYPAIR_B58=<base58-encoded-64-byte-secret-key>

# Optional: filesystem path to a Solana CLI keypair JSON (number array
# of 64 bytes). Used by adapters that expect the legacy file format.
# Either FACILITATOR_KEYPAIR_B58 or this path must be set.
FACILITATOR_KEYPAIR_JSON=

# Optional: HTTP server port. Default 3000.
PORT=3000

# Optional: default facilitator name advertised in /facilitators
TRUSTGATE_DEFAULT_FACILITATOR=
