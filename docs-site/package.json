{
  "name": "docs-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "prebuild": "node scripts/build-namespaces-table.mjs && node scripts/build-changelog.mjs",
