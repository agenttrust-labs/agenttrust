# @agenttrust-sdk/mcp — read tools work with no env beyond defaults;
# write tools require KEYPAIR_B58. NEVER commit a real value.

# Solana RPC + network (defaults: api.devnet.solana.com / solana-devnet)
RPC_URL=https://api.devnet.solana.com
NETWORK=solana-devnet

# Required for write tools (init_authority, set_killswitch,
# request_validation, respond_to_validation, emit_feedback)
KEYPAIR_B58=<base58-encoded-64-byte-secret-key>

# Optional: stdio (default) | http
MCP_TRANSPORT=stdio
# Optional: HTTP transport port (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8765
# Optional: facilitator name surfaced in tool replies (e.g. pay-sh)
MCP_DEFAULT_FACILITATOR=
# Optional: docs directory the agenttrust_search_docs tool serves
MCP_DOCS_DIR=
# Optional: state file the agenttrust_pay_sh_demo_state tool reads
PAY_SH_DEMO_STATE_FILE=
# Optional: gates the integration test suite (1 = enabled)
INTEGRATION=
