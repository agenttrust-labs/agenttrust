# agenttrust-attestor-demo — environment overrides
#
# Devnet ValidationRegistry attestor lifecycle smoke + the Phase J3
# chained-validation trace. Both scripts under scripts/ pick up the
# env at boot.

# Solana RPC endpoint. Defaults to public devnet.
RPC_URL=https://api.devnet.solana.com

# Optional: filesystem path to the facilitator's Solana CLI keypair
# JSON (a 64-byte number array). Defaults to ~/.config/solana/id.json.
KEYPAIR=

# Optional: base58-encoded facilitator secret key. Preferred over the
# KEYPAIR file path when both are set — used by CI runs that don't
# have a ~/.config/solana/id.json file.
FACILITATOR_KEYPAIR_B58=<base58-encoded-64-byte-secret-key>

# Optional: gates the integration test suite. Set to 1 to enable.
INTEGRATION=

# Optional: gates the revoke step at the end of devnet-attestor-flow.ts.
# Set to 1 to revoke; otherwise the attestation stays live.
REVOKE=
