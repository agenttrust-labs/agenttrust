# agenttrust-pay-sh-demo — real-chain mode kicks in whenever
# FACILITATOR_KEYPAIR_B58 is set; otherwise mock-chain. Never commit
# a real keypair value.

# Solana RPC + network (defaults: api.devnet.solana.com / solana-devnet)
RPC_URL=https://api.devnet.solana.com
NETWORK=solana-devnet

# Optional: real-chain facilitator. Without it, demo runs mock-chain
# with a per-process generated keypair.
FACILITATOR_KEYPAIR_B58=<base58-encoded-64-byte-secret-key>
# Optional: filesystem path to a Solana CLI keypair JSON. Used by
# scripts/devnet-smoke.ts when FACILITATOR_KEYPAIR_B58 isn't set.
KEYPAIR=

# Optional: SPL mint to charge for /protected (default: USDC mainnet —
# Surfpool mirrors mainnet mints to localnet)
MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Optional: HTTP server port. Default 3402.
PORT=3402
# Optional: state-file path for cross-run idempotency in the smoke script
STATE_FILE=
# Optional: gates the integration test suite (1 = enabled)
INTEGRATION=
